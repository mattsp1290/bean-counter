# Copy to .env and adjust values for local development.
#
# SQLite needs no container:
#   BN_DRIVER=sqlite
#   BN_DSN=file:bean-counter.db
#
# Postgres with docker-compose.yml:
#   docker compose up -d postgres
#   BN_DRIVER=postgres
#   BN_DSN=postgres://bean_counter:bean_counter@localhost:5432/bean_counter?sslmode=disable
#
# MySQL with docker-compose.yml:
#   docker compose up -d mysql
#   BN_DRIVER=mysql
#   BN_DSN=bean_counter:bean_counter@tcp(localhost:3306)/bean_counter?parseTime=true

BN_DRIVER=sqlite
BN_DSN=file:bean-counter.db
BN_PROJECT_PREFIX=bean-counter
BN_ACTOR=bean-counter
BN_CORS_ORIGIN=http://localhost:5173
BN_ADDR=:8080

# Optional store pool tuning.
# BN_MAX_CONNS=10
# BN_MIN_CONNS=5
# BN_CONNECT_TIMEOUT=5s

# Local database container defaults used by docker-compose.yml.
POSTGRES_DB=bean_counter
POSTGRES_USER=bean_counter
POSTGRES_PASSWORD=bean_counter
POSTGRES_PORT=5432

MYSQL_DATABASE=bean_counter
MYSQL_USER=bean_counter
MYSQL_PASSWORD=bean_counter
MYSQL_ROOT_PASSWORD=bean_counter_root
MYSQL_PORT=3306
